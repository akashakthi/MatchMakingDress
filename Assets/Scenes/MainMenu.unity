  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Kebaya Encim adalah kebaya tradisional Indonesia yang memiliki ciri khas
    berupa desain yang dipengaruhi budaya Tionghoa dengan warna-warna cerah dan motif
    yang khas.

    Kebaya ini biasanya menggunakan bahan tipis seperti katun atau
    voile dengan potongan yang ringan dan nyaman dipakai sehari-hari.

    Ciri khas
    lainnya adalah hiasan bordir halus bermotif bunga pada bagian depan, lengan,
    dan bawah kebaya yang memberikan kesan manis dan feminin.

    Biasanya, kebaya
    Encim terdiri dari atasan yang dipadukan dengan bawahan berupa kain batik atau
    kain tradisional lainnya.

'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: dca4a4889af04024e866675dc9595e1c, type: 2}
  m_sharedMaterial: {fileID: 2951696529170446369, guid: dca4a4889af04024e866675dc9595e1c, type: 2}
